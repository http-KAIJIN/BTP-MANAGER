POSTGRES_DB=btp_manager
POSTGRES_USER=btp_manager
POSTGRES_PASSWORD=btp_manager_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://btp_manager:btp_manager_password@postgres:5432/btp_manager
