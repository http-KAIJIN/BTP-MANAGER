enum NumberingEntityType {
  QUOTE
  INVOICE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED_TO_INVOICE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model NumberingSequence {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType NumberingEntityType  @map("entity_type")
  prefix     String               @db.VarChar(10)
  year       Int
  lastNumber Int                  @map("last_number")

  @@unique([entityType, year], map: "uq_numbering_sequence_entity_year")
  @@map("numbering_sequences")
}

model Quote {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteNumber     String      @unique @map("quote_number") @db.VarChar(40)
  clientId        String      @map("client_id") @db.Uuid
  projectId       String?     @map("project_id") @db.Uuid
  quoteDate       DateTime    @map("quote_date") @db.Date
  validUntil      DateTime?   @map("valid_until") @db.Date
  status          QuoteStatus @default(DRAFT)
  title           String?     @db.VarChar(255)
  notes           String?     @db.Text
  subtotalHT      Decimal     @map("subtotal_ht") @db.Decimal(14, 2)
  taxRate         Decimal     @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalTTC        Decimal     @map("total_ttc") @db.Decimal(14, 2)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String? @map("created_by") @db.Uuid
  updatedById String? @map("updated_by") @db.Uuid
  deletedById String? @map("deleted_by") @db.Uuid

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("QuoteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy User?     @relation("QuoteDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  items    QuoteItem[]
  invoices Invoice[]

  @@index([clientId], map: "idx_quotes_client")
  @@index([projectId], map: "idx_quotes_project")
  @@index([quoteDate], map: "idx_quotes_date")
  @@index([status], map: "idx_quotes_status")
  @@index([deletedAt], map: "idx_quotes_deleted_at")
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId     String  @map("quote_id") @db.Uuid
  description String  @db.Text
  quantity    Decimal @db.Decimal(14, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(14, 2)
  totalHT     Decimal @map("total_ht") @db.Decimal(14, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId], map: "idx_quote_items_quote")
  @@map("quote_items")
}

model Invoice {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber   String        @unique @map("invoice_number") @db.VarChar(40)
  quoteId         String?       @map("quote_id") @db.Uuid
  clientId        String        @map("client_id") @db.Uuid
  projectId       String?       @map("project_id") @db.Uuid
  invoiceDate     DateTime      @map("invoice_date") @db.Date
  dueDate         DateTime?     @map("due_date") @db.Date
  status          InvoiceStatus @default(DRAFT)
  title           String?       @db.VarChar(255)
  notes           String?       @db.Text
  subtotalHT      Decimal       @map("subtotal_ht") @db.Decimal(14, 2)
  taxRate         Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalTTC        Decimal       @map("total_ttc") @db.Decimal(14, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(14, 2)
  remainingAmount Decimal       @map("remaining_amount") @db.Decimal(14, 2)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String? @map("created_by") @db.Uuid
  updatedById String? @map("updated_by") @db.Uuid
  deletedById String? @map("deleted_by") @db.Uuid

  quote     Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy User?     @relation("InvoiceDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  items    InvoiceItem[]
  payments InvoicePayment[]

  @@index([clientId], map: "idx_invoices_client")
  @@index([projectId], map: "idx_invoices_project")
  @@index([quoteId], map: "idx_invoices_quote")
  @@index([invoiceDate], map: "idx_invoices_date")
  @@index([status], map: "idx_invoices_status")
  @@index([deletedAt], map: "idx_invoices_deleted_at")
  @@map("invoices")
}

